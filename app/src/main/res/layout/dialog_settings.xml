<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/dialog_bg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ 设置"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/lobster_red"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <!-- ========== 系统权限设置区域 ========== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 系统权限设置"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/lobster_red"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击下方按钮，系统会自动跳转到对应的设置页面"
            android:textSize="12sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="12dp" />

        <!-- 基础权限 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="基础权限"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnPermissionOverlay"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🔲 悬浮窗权限"
                android:backgroundTint="#9C27B0"
                android:layout_marginEnd="8dp"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnPermissionNotification"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🔔 通知监听"
                android:backgroundTint="#9C27B0"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 后台运行权限 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="后台运行权限"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="为保证小龙虾不被系统杀掉，请开启以下权限"
            android:textSize="11sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnIgnoreBattery"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🔋 电池优化"
                android:backgroundTint="#FF5722"
                android:layout_marginEnd="8dp"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnAutoStart"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🚀 自启动管理"
                android:backgroundTint="#FF5722"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 其他权限 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="其他权限"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnInstallPermission"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="📦 安装权限"
                android:backgroundTint="#E91E63"
                android:layout_marginEnd="8dp"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnAppSettings"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="⚙️ 应用详情"
                android:backgroundTint="#607D8B"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <!-- ========== 功能设置区域 ========== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎨 功能设置"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/lobster_red"
            android:layout_marginBottom="12dp" />

        <!-- GLM API Key 配置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI 对话配置"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/apiKeyInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="输入 GLM API Key"
            android:padding="10dp"
            android:background="@drawable/input_bg"
            android:textSize="13sp"
            android:inputType="textPassword"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnSaveKey"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="💾 保存"
                android:backgroundTint="@color/lobster_red"
                android:layout_marginEnd="8dp"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnGetKey"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="🔑 获取Key"
                android:backgroundTint="#4CAF50"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 消息弹窗持续时间 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="消息弹窗持续时间"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="6dp" />

        <RadioGroup
            android:id="@+id/rgPopupDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="6dp">

            <RadioButton
                android:id="@+id/rbDurationForever"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="永久显示（手动关闭）"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/rbDuration10s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 秒"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/rbDurationCustom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自定义"
                android:textSize="13sp" />
        </RadioGroup>

        <EditText
            android:id="@+id/etCustomDuration"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="输入秒数（例如 30）"
            android:padding="10dp"
            android:background="@drawable/input_bg"
            android:textSize="13sp"
            android:inputType="number"
            android:visibility="gone"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnSaveDuration"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="💾 保存持续时间"
            android:backgroundTint="@color/lobster_red"
            android:layout_marginBottom="16dp"
            android:textSize="13sp" />

        <!-- 锁屏通知 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="锁屏通知设置"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="6dp" />

        <CheckBox
            android:id="@+id/cbWakeScreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="锁屏时点亮屏幕"
            android:textSize="13sp" />

        <CheckBox
            android:id="@+id/cbShowContentOnLockScreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="锁屏时显示消息内容"
            android:textSize="13sp" />

        <CheckBox
            android:id="@+id/cbAlertEveryTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="每次通知都触发亮屏/声音"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnSaveLockScreen"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:text="💾 保存锁屏设置"
            android:backgroundTint="@color/lobster_red"
            android:layout_marginBottom="16dp"
            android:textSize="13sp" />

        <!-- 系统信息 -->
        <TextView
            android:id="@+id/tvSystemInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="系统信息加载中..."
            android:textSize="11sp"
            android:textColor="@color/gray"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
