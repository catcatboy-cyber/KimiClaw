<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/dialog_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙️ 设置"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/lobster_red"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- GLM API Key 配置 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GLM API Key 配置"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/apiKeyInput"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="输入 GLM API Key"
        android:padding="12dp"
        android:background="@drawable/input_bg"
        android:textSize="14sp"
        android:inputType="textPassword"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btnSaveKey"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="💾 保存"
            android:backgroundTint="@color/lobster_red"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnGetKey"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🔑 获取Key"
            android:backgroundTint="#4CAF50" />
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="16dp" />

    <!-- 配置备份 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="配置备份与恢复"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/configStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="未找到备份配置"
        android:textSize="12sp"
        android:textColor="@color/gray"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnExportConfig"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="📤 导出配置"
            android:backgroundTint="#2196F3"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnImportConfig"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="📥 导入配置"
            android:backgroundTint="#FF9800" />
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp" />

    <!-- 权限设置 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="权限设置"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnPermissionOverlay"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🔲 悬浮窗"
            android:backgroundTint="#9C27B0"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnPermissionNotification"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🔔 通知监听"
            android:backgroundTint="#9C27B0" />
    </LinearLayout>

</LinearLayout>
